# ──────────────────────────────────────────────────────────
# Firebase 클라이언트 설정 (Firebase Console > 프로젝트 설정 > 일반 > 내 앱)
# ──────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ──────────────────────────────────────────────────────────
# Kakao JavaScript 앱 키 (developers.kakao.com > 내 애플리케이션 > 앱 키 > JavaScript 키)
# ──────────────────────────────────────────────────────────
VITE_KAKAO_APP_KEY=

# ──────────────────────────────────────────────────────────
# Firebase Admin SDK (Firebase Console > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성)
# ──────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
